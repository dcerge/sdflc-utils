{
  "name": "@sdflc/utils",
  "version": "1.0.28",
  "description": "A set of utilites used in the @sdflc libraries and related projects. Purpose is to minimize usage of 3rd party libraries.",
  "type": "commonjs",
  "exports": {
    ".": {
      "import": "./build/esm/index.js",
      "require": "./build/index.js"
    }
  },
  "main": "./build/index.js",
  "module": "./build/esm/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build/**/*"
  ],
  "scripts": {
    "build": "rimraf ./build && tsc && tsc -p tsconfig.esm.json",
    "lint": "ESLINT_USE_FLAT_CONFIG=true eslint .",
    "test": "jest --config jest.config.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "husky",
    "prepublishOnly": "npm test && npm run lint",
    "preversion": "npm run lint",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "author": "Sergey Demidenko",
  "license": "ISC",
  "dependencies": {
    "check-types": "^11.2.3",
    "dayjs": "^1.11.20",
    "lodash": "^4.17.23"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/check-types": "^11.2.2",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "run-script-os": "^1.1.6",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dcerge/sdflc-utils.git"
  },
  "keywords": [
    "utils",
    "sdflc"
  ],
  "bugs": {
    "url": "https://github.com/dcerge/sdflc-utils/issues"
  },
  "homepage": "https://github.com/dcerge/sdflc-utils#readme"
}
